# Feature flags — copy to `.env` (or `.env.local`) and adjust per environment.
#
# Vite statically inlines `VITE_*` vars at build time, so changing one requires
# a rebuild (`npm run build`) / dev-server restart. See src/lib/flags.ts.
#
# A flag is OFF only when set to a falsy token (false / 0 / off / no).
# Unset or any other value ⇒ ON (the committed default).

# Account sign-in: header user button, auth modal, and the /settings area.
# Set to `false` to ship an anonymous-only catalog/cart with no auth surface.
VITE_FEATURE_AUTH=false

# Mobile navigation: header hamburger toggle and the dropdown nav it opens.
# Set to `false` to hide the menu toggle (desktop nav links only).
VITE_FEATURE_MOBILE_NAV=false

# Extra header nav links: "Our Story" and "Order Custom" (the "Cakes" link is
# always shown). Defaults OFF — set to `true` to surface them once those
# destinations exist.
VITE_FEATURE_EXTRA_NAV=false

# Shop contact handles for the cart's "Send your order in" buttons. See
# src/lib/contacts.ts — both default to the live accounts, so these are optional.
# WhatsApp: international number, digits only (no `+` or spaces) → wa.me/<number>.
VITE_WHATSAPP_NUMBER=381665814358
# Telegram: username without the leading `@` → t.me/<username>.
VITE_TELEGRAM_USERNAME=anatolii_tarasov_a
